new file mode 100644
index 0000000..3c1c135
--- /dev/null
+++ b/drivers/net/efinix_tse.h
@@ -0,0 +1,142 @@
+// SPDX-License-Identifier: GPL-2.0+
+/*
+ * Efinix Triple-Speed Ethernet MAC driver
+ *
+ * Copyright (C) 2026 Efinix, Inc.
+ * Author: Teoh Choon Zone <czteoh@efinixinc.com>
+ *
+ */
+
+#ifndef EFINIX_TSE_H
+#define EFINIX_TSE_H
+
+#include <linux/bitops.h>
+
+#define EFINIX_TSE_NAME				"efinix_tse"
+
+#define EFINIX_DEFAULT_HOST_CLOCK		100000000
+#define EFINIX_MAX_MDIO_FREQ			2500000
+#define EFINIX_MDIO_TIMEOUT_MS			20
+#define EFINIX_DMA_TIMEOUT_MS			3000
+#define EFINIX_RESET_DELAY_MS			100
+#define EFINIX_DMA_BURST_LEN			64
+#define EFINIX_TX_DESC_COUNT			2
+#define EFINIX_RX_DESC_COUNT			PKTBUFSRX
+
+/* MAC command register bits */
+#define ETHERNET_CMD_TX_ENA			BIT(0)
+#define ETHERNET_CMD_RX_ENA			BIT(1)
+#define ETHERNET_CMD_PROMIS_EN			BIT(4)
+#define ETHERNET_CMD_CRC_FWD			BIT(6)
+#define ETHERNET_CMD_PAUSE_IGNORE		BIT(8)
+
+/* Speed configuration */
+#define ETH_SPEED_MASK				0x00070000
+#define ETH_SPEED_MASK_10			0x00010000
+#define ETH_SPEED_MASK_100			0x00020000
+#define ETH_SPEED_MASK_1000			0x00040000
+
+/* MAC configuration registers */
+#define TSEMAC_COMMAND_CONFIG			0x0008
+#define TSEMAC_MAC_ADDR_LO			0x000c
+#define TSEMAC_MAC_ADDR_HI			0x0010
+#define TSEMAC_FRM_LENGTH			0x0014
+#define TSEMAC_A_FRAMES_TRANSMITTED_OK		0x0068
+#define TSEMAC_A_FRAMES_RECEIVED_OK		0x006c
+#define TSEMAC_CRC_ERRORS			0x0070
+#define TSEMAC_IF_IN_ERRORS			0x0088
+#define TSEMAC_IF_OUT_ERRORS			0x008c
+#define TSEMAC_MAC_ADDR_MASK_LO			0x0144
+#define TSEMAC_MAC_ADDR_MASK_HI			0x0148
+
+/* MDIO registers */
+#define MDIO_REG_DIVIDER_PRE			0x0100
+#define MDIO_REG_RD_WR_EN			0x0104
+#define MDIO_REG_REG_PHY_ADDR			0x0108
+#define MDIO_REG_WR_DATA			0x010c
+#define MDIO_REG_RD_DATA			0x0110
+#define MDIO_REG_STATUS				0x0114
+
+#define MDIO_DIVIDER_MASK			0x000000ff
+#define MDIO_RD_EN				BIT(0)
+#define MDIO_WR_EN				BIT(1)
+#define MDIO_REG_ADDR_MASK			0x0000001f
+#define MDIO_PHY_ADDR_SHIFT			8
+#define MDIO_PHY_ADDR_MASK			0x00001f00
+#define MDIO_READ_DATA_MASK			0x0000ffff
+#define MDIO_WRITE_DATA_MASK			0x0000ffff
+#define MDIO_STATUS_BUSY			BIT(1)
+
+/* Ethernet control registers */
+#define ETHERNET_CTRL_MAC_RST			0x0200
+#define ETHERNET_CTRL_PHY_RST			0x0204
+#define ETHERNET_CTRL_DMA_RX_RESET		0x0208
+#define ETHERNET_CTRL_DMA_TX_RESET		0x020c
+#define ETHERNET_CTRL_HW_RX_CHECKSUM_EN		0x0210
+#define ETHERNET_CTRL_HW_TX_CHECKSUM_EN		0x0214
+
+/* DMA channel base offsets */
+#define DMASG_RX_BASE				0x0000
+#define DMASG_TX_BASE				0x0080
+
+/* DMA channel registers */
+#define DMA_CH_INPUT_CONFIG			0x000c
+#define DMA_CH_OUTPUT_CONFIG			0x001c
+#define DMA_CH_OUTPUT_CONFIG_MEMORY		BIT(12)
+#define DMA_CH_INPUT_CONFIG_MEMORY		BIT(12)
+#define DMA_CH_INPUT_CONFIG_COMPLETION_ON_PACKET	BIT(13)
+#define DMA_CH_INPUT_CONFIG_WAIT_ON_PACKET	BIT(14)
+#define DMA_CH_STATUS				0x002c
+#define DMA_CH_STATUS_BUSY			BIT(0)
+#define DMA_CH_STATUS_STOP			BIT(2)
+#define DMA_CH_STATUS_LINKED_LIST_START		BIT(4)
+#define DMA_CH_PRIORITY				0x0044
+#define DMA_CH_INTERRUPT_ENABLE			0x0050
+#define DMA_CH_LINKED_LIST_HEAD			0x0070
+#define DMA_CH_BYTE_PER_BURST_MASK		0x0fff
+
+/* DMA descriptor fields */
+#define DMASG_DESC_CTL_BYTES			0x07ffffff
+#define DMASG_DESC_CTL_END_OF_PACKET		BIT(30)
+#define DMASG_DESC_STATUS_BYTES			0x07ffffff
+#define DMASG_DESC_STATUS_COMPLETED		BIT(31)
+
+/* PHY interface types */
+#define TSEMAC_PHY_TYPE_MII			0
+#define TSEMAC_PHY_TYPE_GMII			1
+#define TSEMAC_PHY_TYPE_RGMII_1_3		2
+#define TSEMAC_PHY_TYPE_RGMII_2_0		3
+#define TSEMAC_PHY_TYPE_SGMII			4
+#define TSEMAC_PHY_TYPE_1000BASE_X		5
+
+/* RTL8211F PHY identification */
+#define RTL8211F_PHY_ID				0x001cc916
+#define RTL8211_PHY_ID_MASK			0x00ffffff
+
+struct efinix_tse_desc {
+	u32 status;
+	u32 control;
+	u64 from;
+	u64 to;
+	u64 next;
+} __aligned(64);
+
+struct efinix_tse_priv {
+	void __iomem *regs;
+	void __iomem *dma_regs;
+	struct clk axi_clk;
+	struct mii_dev *bus;
+	struct phy_device *phydev;
+	struct efinix_tse_desc *tx_descs;
+	struct efinix_tse_desc *rx_descs;
+	unsigned long tx_descs_dma;
+	unsigned long rx_descs_dma;
+	unsigned long axi_clk_rate;
+	u32 rx_buf_size;
+	int phyaddr;
+	int active_rx;
+	int rx_head;
+	bool clk_valid;
+};
+
+#endif /* EFINIX_TSE_H */
